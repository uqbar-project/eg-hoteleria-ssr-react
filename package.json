{
  "name": "eg-hoteleria-ssr-react",
  "private": true,
  "scripts": {
    "dev:remix": "pnpm --filter remix dev",
    "dev:remix:watch": "pnpm --filter remix dev",
    "dev:vanilla": "pnpm --filter vanilla dev",
    "dev:vanilla:watch": "pnpm --filter vanilla dev:watch",
    "build:remix": "pnpm --filter remix build",
